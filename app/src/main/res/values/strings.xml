    <string name="setup_guide1_eyebrow">HOW CROC WORKS</string>
    <string name="setup_guide1_title">Simple code, direct transfer, no account mess.</string>
    <string name="setup_guide1_bullet1">Pick files on one phone and croc generates a short one-time code.</string>
    <string name="setup_guide1_bullet2">On the other phone, enter the code or scan the QR to join instantly.</string>
    <string name="setup_guide1_bullet3">The transfer is end-to-end encrypted, so the file stays private in transit.</string>
    <string name="setup_guide2_eyebrow">GOOD TO KNOW</string>
    <string name="setup_guide2_title">This setup only needs patience once.</string>
    <string name="setup_guide2_bullet1">The first run downloads and prepares the croc engine.</string>
    <string name="setup_guide2_bullet2">Later launches reuse that engine, so send and receive feel immediate.</string>
    <string name="setup_guide2_bullet3">Keeping the app open on this screen is enough. No extra action needed.</string>
